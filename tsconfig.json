{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Default",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": false,
    "isolatedModules": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "preserveWatchOutput": true,
    "skipLibCheck": true,
    "strict": true,
    "jsx": "react",
    "paths": {
      "@story-helpers": ["./.storybook/helpers"],
      "@story-helpers/stockfish": ["./.storybook/helpers/stockfish"],
      "@react-chess-tools/react-chess-stockfish": [
        "./packages/react-chess-stockfish/src/index.ts"
      ],
      "@react-chess-tools/react-chess-game": [
        "./packages/react-chess-game/src/index.ts"
      ],
      "@react-chess-tools/react-chess-puzzle": [
        "./packages/react-chess-puzzle/src/index.ts"
      ],
      "@react-chess-tools/react-chess-clock": [
        "./packages/react-chess-clock/src/index.ts"
      ]
    }
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
